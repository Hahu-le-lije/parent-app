{
  "expo": {
    "name": "Hahu-parent",
    "slug": "Hahu-parent",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/hahu_logo.png",
    "scheme": "hahuparent",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/hahu_logo.png",
        "backgroundImage": "./assets/images/hahu_logo.png",
        "monochromeImage": "./assets/images/hahu_logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.izorium.Hahuparent"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/hahu_logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-build-properties"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9b4e8f77-903d-40d2-8613-656a3786cb3f"
      }
    }
  }
}
